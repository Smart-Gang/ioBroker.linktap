{
  "name": "iobroker.linktap",
  "version": "1.0.6",
  "description": "Control your garden irrigation with the LinkTap Wireless Water Timer",
  "author": {
    "name": "Smart-Gang",
    "email": "gangrulez@gmail.com"
  },
  "homepage": "https://github.com/Smart-Gang/ioBroker.linktap",
  "license": "MIT",
  "keywords": [
    "ioBroker",
    "Smart Home",
    "home automation",
    "irrigation",
    "garden",
    "LinkTap"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Smart-Gang/ioBroker.linktap.git"
  },
  "dependencies": {
    "@iobroker/adapter-core": "^3.4.1"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "devDependencies": {
    "@alcalzone/release-script": "^5.2.1",
    "@alcalzone/release-script-plugin-iobroker": "^5.2.0",
    "@alcalzone/release-script-plugin-license": "^5.2.0",
    "@alcalzone/release-script-plugin-manual-review": "^5.2.0",
    "@iobroker/adapter-dev": "^1.5.0",
    "@iobroker/eslint-config": "^2.3.4",
    "@iobroker/testing": "^5.2.2",
    "@tsconfig/node22": "^22.0.5",
    "@types/gulp": "^4.0.18",
    "@types/node": "^22.10.5",
    "@types/proxyquire": "^1.3.31",
    "eslint-plugin-n": "^18.2.1",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-promise": "^7.3.0",
    "eslint-plugin-sonarjs": "^4.1.0",
    "globals": "^17.7.0",
    "proxyquire": "^2.1.3",
    "tslint": "^6.1.3",
    "typescript": "^6.0.3"
  },
  "main": "main.js",
  "files": [
    "admin{,/!(src)/**}/!(tsconfig|tsconfig.*).json",
    "admin{,/!(src)/**}/*.{html,css,png,svg,jpg,js}",
    "lib/",
    "www/",
    "io-package.json",
    "LICENSE",
    "main.js"
  ],
  "scripts": {
    "test:js": "mocha --config test/mocharc.custom.json \"{!(node_modules|test)/**/*.test.js,*.test.js,test/**/test!(PackageFiles|Startup).js}\"",
    "test:package": "mocha test/package --exit",
    "test:integration": "mocha test/integration --exit",
    "test": "npm run test:js && npm run test:package",
    "lint": "eslint -c eslint.config.mjs .",
    "lint:ts": "eslint -c eslint.config.mjs .",
    "translate": "node --experimental-require-module node_modules/@iobroker/adapter-dev/bin/translate-adapter.js",
    "release:standard": "release-script"
  },
  "bugs": {
    "url": "https://github.com/Smart-Gang/ioBroker.linktap/issues"
  },
  "readmeFilename": "README.md"
}
